{
  "name": "express-typescript-boilerplate",
  "version": "1.0.0",
  "description": "Production-ready Express.js + TypeScript + PostgreSQL boilerplate",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch --clear-screen=false src/server.ts",
    "prebuild": "rimraf dist",
    "build": "tsc && tsc-alias",
    "test": "jest --runInBand --silent",
    "test:coverage": "jest --runInBand --coverage",
    "lint": "eslint './src/**/*.{js,ts}'",
    "lint:fix": "eslint './src/**/*.{js,ts}' --fix",
    "prettier": "prettier --check './src/**/*.{js,ts}'",
    "prettier:fix": "prettier --write './src/**/*.{js,ts}'",
    "seed:dev": "tsx src/db/seeds",
    "seed": "node dist/db/seeds",
    "db:generate": "drizzle-kit generate --name=$npm_config_name",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "prepare": "husky",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "test:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "test:down": "docker compose -f docker-compose.test.yml down"
  },
  "keywords": [],
  "author": "Loc Nguyen",
  "license": "ISC",
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "8.5.0",
    "@bull-board/api": "6.21.2",
    "@bull-board/express": "6.21.2",
    "argon2": "0.44.0",
    "bullmq": "5.73.5",
    "compression": "1.8.1",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "csrf-csrf": "4.0.3",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "express": "5.2.1",
    "express-rate-limit": "8.3.2",
    "express-zod-safe": "3.2.1",
    "helmet": "8.1.0",
    "http-status-codes": "2.3.0",
    "inversify": "^8.1.0",
    "ioredis": "5.10.1",
    "jsonwebtoken": "9.0.3",
    "pg": "8.20.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "rate-limit-redis": "4.3.1",
    "reflect-metadata": "^0.2.2",
    "swagger-ui-express": "5.0.1",
    "zod": "4.3.6"
  },
  "overrides": {
    "lodash": "4.18.1"
  },
  "devDependencies": {
    "@commitlint/cli": "19.8.1",
    "@commitlint/config-conventional": "19.8.1",
    "@types/compression": "1.8.1",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.6.0",
    "@types/pg": "8.20.0",
    "@types/supertest": "6.0.3",
    "@types/swagger-ui-express": "4.1.8",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "globals": "17.5.0",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "lint-staged": "16.2.7",
    "pino-pretty": "13.1.3",
    "prettier": "3.8.2",
    "rimraf": "6.1.3",
    "supertest": "7.2.2",
    "ts-jest": "29.4.9",
    "tsc-alias": "1.8.16",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.1"
  },
  "lint-staged": {
    "src/**/*.{ts,js}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
